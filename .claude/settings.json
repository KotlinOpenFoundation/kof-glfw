{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Read(.)",
      "Bash(find . *)",
      "Bash(./gradlew:*)",
      "Bash(docker compose:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(rm -rf .gradle/configuration-cache)",
      "mcp__ide"
    ],
    "deny": [
      "Write(.claude/)",
      "Write(.git/)",
      "Write(.idea/)",
      "Bash(git:*)"
    ]
  }
}
